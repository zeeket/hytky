users:
  - name: dettmann
    shell: /bin/bash
    groups: sudo, docker
    ssh_authorized_keys:
      - ${pub_key}
      - ${deploy_key}
chpasswd:
  expire: false
  users:
  - {name: root, password: ${ROOT_PASSWORD}, type: text}
  - {name: dettmann, type: RANDOM }
ssh_pwauth: false
write_files:
  - path: /opt/secrets/.env
    content: |
      ${indent(6, dotenv)}
  - path: /opt/secrets/.hytkybot.env
    content: |
      ${indent(6, hytkybot_dotenv)}
  - path: /opt/secrets/.gcalservice.env
    content: |
      ${indent(6, gcalservice_dotenv)}